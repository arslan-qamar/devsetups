# -*- mode: ruby -*-
# vi: set ft=ruby :

require 'shellwords'

def interface_up?(name)
  operstate_path = "/sys/class/net/#{name}/operstate"
  File.exist?(operstate_path) && File.read(operstate_path).strip == 'up'
end

def linux_bridge?(name)
  File.directory?("/sys/class/net/#{name}/bridge")
end

def default_route_interface
  route = `ip route get 1.1.1.1 2>/dev/null`.strip
  route[/\bdev\s+(\S+)/, 1].to_s
end

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu-dev"
  # Set VM name to the folder name where `vagrant up` is run
  config.vm.define 'vm'
  vm_name = File.basename(Dir.pwd)
  config.vm.hostname = "#{vm_name}-vm"
  config.ssh.username = "ubuntu"  
  config.ssh.private_key_path = [ENV.fetch('VAGRANT_CUSTOM_KEY_PATH')] 
  config.ssh.insert_key = false

  # Prefer an explicit override, then br0, then any other active host bridge.
  # If no bridge exists, fall back to the active uplink interface and let
  # libvirt attach the guest in direct bridge mode instead of dropping back to
  # a private-only NIC.
  public_network_options = begin
    override = ENV['VAGRANT_BRIDGE'].to_s.strip
    chosen_interface = nil

    if !override.empty? && File.directory?("/sys/class/net/#{override}") && interface_up?(override)
      chosen_interface = override
    else
      candidate_bridges = Dir.glob('/sys/class/net/*/bridge').map { |path| File.basename(File.dirname(path)) }
      active_bridges = candidate_bridges.select do |name|
        interface_up?(name)
      end.reject do |name|
        name =~ /^(virbr|docker)/
      end

      chosen_interface = active_bridges.find { |name| name == 'br0' } ||
        active_bridges.first

      if chosen_interface.nil?
        uplink = default_route_interface
        if !uplink.empty? && interface_up?(uplink) && uplink !~ /^(virbr|docker|vnet|tap)/
          chosen_interface = uplink
        end
      end
    end

    if chosen_interface
      if linux_bridge?(chosen_interface)
        {
          type: 'public_network',
          options: {
            libvirt__dev: chosen_interface,
            libvirt__mode: 'bridge',
            libvirt__type: 'bridge'
          }
        }
      else
        {
          type: 'public_network',
          options: {
            dev: chosen_interface,
            libvirt__dev: chosen_interface,
            libvirt__mode: 'bridge',
            libvirt__type: 'direct'
          }
        }
      end
    end
  end

    ensure_vagrant_libvirt_network = <<~SHELL
      if command -v virsh >/dev/null 2>&1 && virsh -c qemu:///system net-info vagrant-libvirt >/dev/null 2>&1; then
        virsh -c qemu:///system net-autostart vagrant-libvirt >/dev/null 2>&1 || true
        virsh -c qemu:///system net-start vagrant-libvirt >/dev/null 2>&1 || true
      fi
    SHELL

    config.trigger.before :up do |trigger|
      trigger.info = "Ensuring libvirt network vagrant-libvirt is active before boot"
      trigger.run = {
        inline: "/bin/bash -lc #{Shellwords.escape(ensure_vagrant_libvirt_network)}"
      }
    end

    config.trigger.after :up do |trigger|
      trigger.info = "Marking libvirt network vagrant-libvirt to autostart"
      trigger.run = {
        inline: "/bin/bash -lc #{Shellwords.escape(ensure_vagrant_libvirt_network)}"
      }
    end

  if public_network_options
    config.vm.network public_network_options[:type], **public_network_options[:options]
  else
    config.vm.network "private_network", type: "dhcp"
  end
  
  config.vm.provider "libvirt" do |libvirt|
    libvirt.driver = "kvm"
    libvirt.cpus = 6
    libvirt.memory = 16384
    libvirt.graphics_type = "spice"
    libvirt.graphics_autoport = true
    libvirt.keymap = "en-us"
    libvirt.video_type = "virtio"
    libvirt.video_vram = 4096
    libvirt.channel type: 'spicevmc', target_name: 'com.redhat.spice.0', target_type: 'virtio'
  end

  # Copy host timezone file to a temporary location in the VM
  config.vm.provision "file", source: "/etc/timezone", destination: "/tmp/host-timezone"

  # Ensure the timezone is set correctly
  config.vm.provision "shell", inline: <<-SHELL
    set -e
    echo "Moving timezone file to /etc/timezone..."
    sudo cp /tmp/host-timezone /etc/timezone
    echo "Updating timezone using dpkg-reconfigure..."
    sudo ln -sf /usr/share/zoneinfo/$(cat /etc/timezone) /etc/localtime
    sudo dpkg-reconfigure -f noninteractive tzdata
  SHELL

end